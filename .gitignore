# ── Binaries ──────────────────────────────────────────────────────────────────
/bin/
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Build output (kubebuilder places operator binary here)
platformer
platformer-operator
platformer-cli

# ── Go ────────────────────────────────────────────────────────────────────────
# Test binary, built with `go test -c`
*.test

# Coverage output
*.out
coverage.html

# Go workspace file (local only)
go.work
go.work.sum

# ── Kubernetes / kubebuilder ───────────────────────────────────────────────────
# Generated CRD manifests (re-generated by `make manifests`)
config/crd/bases/
config/rbac/

# kubebuilder testenv binaries
testbin/

# ── AWS ───────────────────────────────────────────────────────────────────────
# Never commit credentials
.aws/
*.pem
*.p12

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.secret
secrets/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
desktop.ini
